{
  "name": "preckon-host",
  "version": "1.0.0",
  "private": true,
  "description": "Preckon Host — multi-tenant control-plane backend + console (Next.js 15 + MySQL 8)",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:import": "node scripts/db-import.mjs",
    "db:seed": "node scripts/db-import.mjs --seed-only",
    "seed:owner": "node scripts/seed-owner.mjs",
    "seed:demo-tenant": "node scripts/seed-demo-tenant.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "better-auth": "^1.2.7",
    "mysql2": "^3.11.5",
    "next": "15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uuidv7": "^1.0.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "dotenv": "^16.4.7",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  }
}
