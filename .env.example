# ─────────────────────────────────────────────────────────────
# Preckon Host — environment
# Copy to `.env` and fill in. Never commit `.env`.
# ─────────────────────────────────────────────────────────────

# MySQL 8 (XAMPP/MAMP default shown). phpMyAdmin manages the same DB.
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=
DATABASE_NAME=preckon_host

# Better Auth — host-only identity pool.
# Generate a 32+ char secret: `openssl rand -base64 32`
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
BETTER_AUTH_URL=http://localhost:3000

# Service-to-service token the TENANT plane presents to the internal
# entitlement + usage endpoints (§5.5 / §7.6). Rotate periodically.
INTERNAL_SERVICE_TOKEN=change-me-service-token

# Stripe (§7). Left blank → billing endpoints run in "mirror-only" mode
# and skip live Stripe calls (clearly logged). Fill in to go live.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Transactional email provider (§9). Blank → email is logged, not sent.
EMAIL_PROVIDER=postmark
EMAIL_FROM_ADDRESS=noreply@preckon.com
EMAIL_API_KEY=

# Object storage for tenant logos / exports (§3.5). Blank → local ./storage.
STORAGE_BUCKET=
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
